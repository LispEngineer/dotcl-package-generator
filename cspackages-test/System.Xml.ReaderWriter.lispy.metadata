  (:name "XmlCharacterData" :fully-qualified-name "System.Xml.XmlCharacterData" :namespace "System.Xml" :kind :class :documentation (:summary "Provides text manipulation methods that are used by several classes.") :superclass "System.Xml.XmlLinkedNode" :interfaces ("System.Collections.IEnumerable" "System.ICloneable" "System.Xml.XPath.IXPathNavigable") :flags (:abstract) :properties ((:name "Data" :type "System.String" :readable t :writeable t :get-method "get_Data" :set-method "set_Data" :documentation (:summary "Contains the data of the node." :returns "The data of the node.")) (:name "InnerText" :type "System.String" :readable t :writeable t :get-method "get_InnerText" :set-method "set_InnerText" :documentation (:summary "Gets or sets the concatenated values of the node and all the children of the node." :returns "The concatenated values of the node and all the children of the node.")) (:name "Length" :type "System.Int32" :readable t :get-method "get_Length" :documentation (:summary "Gets the length of the data, in characters." :returns "The length, in characters, of the string in the System.Xml.XmlCharacterData.Data property. The length may be zero; that is, CharacterData nodes can be empty.")) (:name "Value" :type "System.String" :readable t :writeable t :get-method "get_Value" :set-method "set_Value" :documentation (:summary "Gets or sets the value of the node." :returns "The value of the node."))) :constructors ((:protected-internal t :parameters ((:name "data" :type "System.String") (:name "doc" :type "System.Xml.XmlDocument")) :documentation (:summary "Initializes a new instance of the System.Xml.XmlCharacterData class." :parameters ((:name "data" :description "String that contains character data to be added to document.") (:name "doc" :description "System.Xml.XmlDocument to contain character data."))))) :methods ((:name "AppendData" :return-type "System.Void" :parameters ((:name "strData" :type "System.String")) :documentation (:summary "Appends the specified string to the end of the character data of the node." :parameters ((:name "strData" :description "The string to insert into the existing string.")))) (:name "DeleteData" :return-type "System.Void" :parameters ((:name "offset" :type "System.Int32") (:name "count" :type "System.Int32")) :documentation (:summary "Removes a range of characters from the node." :parameters ((:name "offset" :description "The position within the string to start deleting.") (:name "count" :description "The number of characters to delete.")))) (:name "InsertData" :return-type "System.Void" :parameters ((:name "offset" :type "System.Int32") (:name "strData" :type "System.String")) :documentation (:summary "Inserts the specified string at the specified character offset." :parameters ((:name "offset" :description "The position within the string to insert the supplied string data.") (:name "strData" :description "The string data that is to be inserted into the existing string.")))) (:name "ReplaceData" :return-type "System.Void" :parameters ((:name "offset" :type "System.Int32") (:name "count" :type "System.Int32") (:name "strData" :type "System.String")) :documentation (:summary "Replaces the specified number of characters starting at the specified offset with the specified string." :parameters ((:name "offset" :description "The position within the string to start replacing.") (:name "count" :description "The number of characters to replace.") (:name "strData" :description "The new data that replaces the old string data.")))) (:name "Substring" :return-type "System.String" :parameters ((:name "offset" :type "System.Int32") (:name "count" :type "System.Int32")) :documentation (:summary "Retrieves a substring of the full string from the specified range." :returns "The substring corresponding to the specified range." :parameters ((:name "offset" :description "The position within the string to start retrieving. An offset of zero indicates the starting point is at the start of the data.") (:name 