e" :description "The attribute to insert.") (:name "refNode" :description "The reference attribute. newNode is placed after the refNode.")))) (:name "InsertBefore" :return-type "System.Xml.XmlAttribute" :parameters ((:name "newNode" :type "System.Xml.XmlAttribute") (:name "refNode" :type "System.Xml.XmlAttribute")) :documentation (:summary "Inserts the specified attribute immediately before the specified reference attribute." :returns "The to insert into the collection." :parameters ((:name "newNode" :description "The attribute to insert.") (:name "refNode" :description "The reference attribute. newNode is placed before the refNode.")))) (:name "Prepend" :return-type "System.Xml.XmlAttribute" :parameters ((:name "node" :type "System.Xml.XmlAttribute")) :documentation (:summary "Inserts the specified attribute as the first node in the collection." :returns "The added to the collection." :parameters ((:name "node" :description "The attribute to insert.")))) (:name "Remove" :return-type "System.Xml.XmlAttribute" :parameters ((:name "node" :type "System.Xml.XmlAttribute")) :documentation (:summary "Removes the specified attribute from the collection." :returns "The node removed or if it is not found in the collection." :parameters ((:name "node" :description "The attribute to remove.")))) (:name "RemoveAll" :return-type "System.Void" :documentation (:summary "Removes all attributes from the collection.")) (:name "RemoveAt" :return-type "System.Xml.XmlAttribute" :parameters ((:name "i" :type "System.Int32")) :documentation (:summary "Removes the attribute corresponding to the specified index from the collection." :returns "Returns if there is no attribute at the specified index." :parameters ((:name "i" :description "The index of the node to remove. The first node has index 0.")))) (:name "SetNamedItem" :return-type "System.Xml.XmlNode" :parameters ((:name "node" :type "System.Xml.XmlNode")) :documentation (:summary "Adds a System.Xml.XmlNode using its System.Xml.XmlNode