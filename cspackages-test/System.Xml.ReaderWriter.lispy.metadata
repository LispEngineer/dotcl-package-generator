e, . A value of indicates that the value of the attribute came from the DTD.")) (:name "Value" :type "System.String" :readable t :writeable t :get-method "get_Value" :set-method "set_Value" :documentation (:summary "Gets or sets the value of the node." :returns "The value returned depends on the System.Xml.XmlNode.NodeType of the node. For nodes, this property is the value of attribute."))) :constructors ((:protected-internal t :parameters ((:name "prefix" :type "System.String") (:name "localName" :type "System.String") (:name "namespaceURI" :type "System.String") (:name "doc" :type "System.Xml.XmlDocument")) :documentation (:summary "Initializes a new instance of the System.Xml.XmlAttribute class." :parameters ((:name "prefix" :description "The namespace prefix.") (:name "localName" :description "The local name of the attribute.") (:name "namespaceURI" :description "The namespace uniform resource identifier (URI).") (:name "doc" :description "The parent XML document."))))) :methods ((:name "AppendChild" :return-type "System.Xml.XmlNode" :parameters ((:name "newChild" :type "System.Xml.XmlNode")) :documentation (:summary "Adds the specified node to the end of the list of child nodes, of this node." :returns "The System.Xml.XmlNode added." :parameters ((:name "newChild" :description "The System.Xml.XmlNode to add.")))) (:name "CloneNode" :return-type "System.Xml.XmlNode" :parameters ((:name "deep" :type "System.Boolean")) :documentation (:summary "Creates a duplicate of this node." :returns "The duplicate node." :parameters ((:name "deep" :description "to recursively clone the subtree under the specified node; to clone only the node itself.")))) (:name "InsertAfter" :return-type "System.Xml.XmlNode" :parameters ((:name "newChild" :type "System.Xml.XmlNode") (:name "refChild" :type "System.Xml.XmlNode")) :documentation (:summary "Inserts the specified node immediately after the specified reference node." :returns "The System.Xml.XmlNode inserted." :parameters ((:name 