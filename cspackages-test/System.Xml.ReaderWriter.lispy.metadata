) (:name "DoNotEscapeUriAttributes" :type "System.Boolean" :readable t :writeable t :get-method "get_DoNotEscapeUriAttributes" :set-method "set_DoNotEscapeUriAttributes" :documentation (:summary "Gets or sets a value that indicates whether the System.Xml.XmlWriter does not escape URI attributes." :returns "if the System.Xml.XmlWriter does not escape URI attributes; otherwise, . The default is .")) (:name "Encoding" :type "System.Text.Encoding" :readable t :writeable t :get-method "get_Encoding" :set-method "set_Encoding" :documentation (:summary "Gets or sets the type of text encoding to use." :returns "The text encoding to use. The default is .")) (:name "Indent" :type "System.Boolean" :readable t :writeable t :get-method "get_Indent" :set-method "set_Indent" :documentation (:summary "Gets or sets a value indicating whether to indent elements." :returns "to write individual elements on new lines and indent; otherwise, . The default is .")) (:name "IndentChars" :type "System.String" :readable t :writeable t :get-method "get_IndentChars" :set-method "set_IndentChars" :documentation (:summary "Gets or sets the character string to use when indenting. This setting is used when the System.Xml.XmlWriterSettings.Indent property is set to ." :returns "The character string to use when indenting. This can be set to any string value. However, to ensure valid XML, you should specify only valid white space characters, such as space characters, tabs, carriage returns, or line feeds. The default is two spaces.")) (:name "NamespaceHandling" :type "System.Xml.NamespaceHandling" :readable t :writeable t :get-method "get_NamespaceHandling" :set-method "set_NamespaceHandling" :documentation (:summary "Gets or sets a value that indicates whether the System.Xml.XmlWriter should remove duplicate namespace declarations when writing XML content. The default behavior is for the writer to output all namespace declarations that are present in the writer's namespace resolver." :returns "The Sys