eturn-type "System.LocalDataStoreSlot" :parameters ((:name "name" :type "System.String")) :documentation (:summary "Allocates a named data slot on all threads. For better performance, use fields that are marked with the System.ThreadStaticAttribute attribute instead." :returns "The allocated named data slot on all threads." :parameters ((:name "name" :description "The name of the data slot to be allocated.")))) (:name "BeginCriticalRegion" :is-static t :return-type "System.Void" :documentation (:summary "Notifies a host that execution is about to enter a region of code in which the effects of a thread abort or unhandled exception might jeopardize other tasks in the application domain.")) (:name "BeginThreadAffinity" :is-static t :return-type "System.Void" :documentation (:summary "Notifies a host that managed code is about to execute instructions that depend on the identity of the current physical operating system thread.")) (:name "DisableComObjectEagerCleanup" :return-type "System.Void" :documentation (:summary "Turns off automatic cleanup of runtime callable wrappers (RCW) for the current thread.")) (:name "EndCriticalRegion" :is-static t :return-type "System.Void" :documentation (:summary "Notifies a host that execution is about to enter a region of code in which the effects of a thread abort or unhandled exception are limited to the current task.")) (:name "EndThreadAffinity" :is-static t :return-type "System.Void" :documentation (:summary "Notifies a host that managed code has finished executing instructions that depend on the identity of the current physical operating system thread.")) (:name "Finalize" :return-type "System.Void" :documentation (:summary "Ensures that resources are freed and other cleanup operations are performed when the garbage collector reclaims the System.Threading.Thread object.")) (:name "FreeNamedDataSlot" :is-static t :return-type "System.Void" :parameters ((:name "name" :type "System.String")) :documentation (:summary "Eliminates the association between a name and a slot, for all threads in the process. For better performance, use fields that are marked with the System.ThreadStaticAttribute attribute instead." :parameters ((:name "name" :description "The name of the data slot to be freed.")))) (:name "GetApartmentState" :return-type "System.Threading.ApartmentState" :documentation (:summary "Returns an System.Threading.ApartmentState value indicating the apartment state." :returns "One of the System.Threading.ApartmentState values indicating the apartment state of the managed thread. The default is System.Threading.ApartmentState.Unknown.")) (:name "GetCompressedStack" :return-type "System.Threading.CompressedStack" :documentation (:summary "Returns a System.Threading.CompressedStack object that can be used to capture the stack for the current thread.")) (:name "GetCurrentProcessorId" :is-static t :return-type "System.Int32" :documentation (:summary "Gets an ID used to indicate on which processor the current thread is executing." :returns "An integer representing the cached processor ID.")) (:name "GetData" :is-static t :return-type "System.Object" :parameters ((:name "slot" :type "System.LocalDataStoreSlot")) :documentation (:summary "Retrieves the value from the specified slot on the current thread, within the current thread's current domain. For better performance, use fields that are marked with the System.ThreadStaticAttribute attribute instead." :returns "The retrieved value." :parameters ((:name "slot" :description "The System.LocalDataStoreSlot from which to get the value.")))) (:name "GetDomain" :is-static t :return-type "System.AppDomain" :documentation (:summary "Returns the current domain in which the current thread is running." :returns "An System.AppDomain representing the current application domain of the running thread.")) (:name "GetDomainID" :is-static t :return-type "System.Int32" :documentation (:summary "Returns a unique application domain identifier." :returns "A 32-bit signed integer uniquely identifying the application domain.")) (:name "GetHashCode" :return-type "System.Int32" :documentation (:summary "Returns a hash code for the current thread." :returns "An integer hash code value.")) (:name "GetNamedDataSlot" :is-static t :return-type "System.LocalDataStoreSlot" :parameters ((:name "name" :type "System.String")) :documentation (:summary "Looks up a named data slot. For better performance, use fields that are marked with the System.ThreadStaticAttribute attribute instead." :returns "A System.LocalDataStoreSlot allocated for this thread." :parameters ((:name "name" :description "The name of the local data slot.")))) (:name "Interrupt" :return-type "System.Void" :documentation (:summary "Interrupts a thread that is in the System.Threading.ThreadState.WaitSleepJoin thread state.")) (:name "Join" :return-type "System.Void" :documentation (:summary "Blocks the calling thread until the thread represented by this instance terminates, while continuing to perform standard COM and pumping.")) (:name "Join" :return-type "System.Boolean" :parameters ((:name "millisecondsTimeout" :type "System.Int32")) :documentation (:summary "Blocks the calling thread until the thread represented by this instance terminates or the specified time elapses, while continuing to perform standard COM and SendMessage pumping." :returns "if the thread has terminated; if the thread has not terminated after the amount of time specified by the millisecondsTimeout parameter has elapsed." :parameters ((:name "millisecondsTimeout" :description "The number of milliseconds to wait for the thread to terminate.")))) (:name "Join" :return-type "System.Boolean" :parameters ((:name "timeout" :type "System.TimeSpan")) :documentation (:summary "Blocks the calling thread until the thread represented by this instance terminates or the specified time elapses, while continuing to perform standard COM and SendMessage pumping." :returns "if the thread terminated; if the thread has not terminated after the amount of time specified by the timeout parameter has elapsed." :parameters ((:name "timeout" :description "A System.TimeSpan set to the amount of time to wait for the thread to terminate.")))) (:name "MemoryBarrier" :is-static t :return-type "System.Void" :documentation (:summary "Synchronizes memory access as follows: The processor executing the current thread cannot reorder instructions in such a way that memory accesses prior to the call to System.Threading.Thread.MemoryBarrier execute after memory accesses that follow the call to System.Threading.Thread.MemoryBarrier.")) (:name "ResetAbort" :is-static t :return-type "System.Void" :documentation (:summary "Cancels an System.Threading.Thread.Abort(System.Object) requested for the current thread.")) (:name "Resume" :return-type "System.Void" :documentation (:summary "Resumes a thread that has been suspended.")) (:name "SetApartmentState" :return-type "System.Void" :parameters ((:name "state" :type "System.Threading.ApartmentState")) :documentation (:summary "Sets the apartment state of a thread before it is started." :parameters ((:name "state" :description "The new apartment state.")))) (:name "SetCompressedStack" :return-type "System.Void" :parameters ((:name "stack" :type "System.Threading.CompressedStack")) :documentation (:summary "Applies a captured System.Threading.CompressedStack to the current thread." :parameters ((:name "stack" :description "The System.Threading.CompressedStack object to be applied to the current thread.")))) (:name "SetData" :is-static t :return-type "System.Void" :parameters ((:name "slot" :type "System.LocalDataStoreSlot") (:name "data" :type "System.Object")) :documentation (:summary "Sets the data in the specified slot on the currently running thread, for that thread's current domain. For better performance, use fields marked with the System.ThreadStaticAttribute attribute instead." :parameters ((:name "slot" :description "The System.LocalDataStoreSlot in which to set the value.") (:name "data" :description "The value to be set.")))) (:name "Sleep" :is-static t :return-type "System.Void" :parameters ((:name "millisecondsTimeout" :type "System.Int32")) :documentation (:summary "Suspends the current thread for the specified number of milliseconds." :parameters ((:name "millisecondsTimeout" :description "The number of milliseconds for which the thread is suspended. If the value of the millisecondsTimeout argument is zero, the thread relinquishes the remainder of its time slice to any thread of equal priority that is ready to run. If there are no other threads of equal priority that are ready to run, execution of the current thread is not suspended.")))) (:name "Sleep" :is-static t :return-type "System.Void" :parameters ((:name "timeout" :type "System.TimeSpan")) :documentation (:summary "Suspends the current thread for the specified amount of time." :parameters ((:name "timeout" :description "The amount of time for which the thread is suspended. If the value of the timeout argument is System.TimeSpan.Zero, the thread relinquishes the remainder of its time slice to any thread of equal priority that is ready to run. If there are no other threads of equal priority that are ready to run, execution of the current thread is not suspended.")))) (:name "SpinWait" :is-static t :return-type "System.Void" :parameters ((:name "iterations" :type "System.Int32")) :documentation (:summary "Causes a thread to wait the number of times defined by the iterations parameter." :parameters ((:name "iterations" :description "A 32-bit signed integer that defines how long a thread is to wait.")))) (:name "Start" :return-type "System.Void" :documentation (:summary "Causes the operating system to change the state of the current instance to System.Threading.ThreadState.Running.")) (:name "Start" :return-type "System.Void" :parameters ((:name "parameter" :type "System.Object")) :documentation (:summary "Causes the operating system to change the state of