Object")) :documentation (:summary "Runs a method in the specified compressed stack on the current thread." :parameters ((:name "compressedStack" :description "The System.Threading.CompressedStack to set.") (:name "callback" :description "A System.Threading.ContextCallback that represents the method to be run in the specified security context.") (:name "state" :description "The object to be passed to the callback method."))))))
