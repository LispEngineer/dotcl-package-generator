  (:name "Thread" :fully-qualified-name "System.Threading.Thread" :namespace "System.Threading" :kind :class :documentation (:summary "Creates and controls a thread, sets its priority, and gets its status.") :superclass "System.Runtime.ConstrainedExecution.CriticalFinalizerObject" :flags (:sealed) :properties ((:name "ApartmentState" :type "System.Threading.ApartmentState" :readable t :writeable t :get-method "get_ApartmentState" :set-method "set_ApartmentState" :documentation (:summary "Gets or sets the apartment state of this thread." :returns "One of the System.Threading.ApartmentState values. The initial value is .")) (:name "CurrentCulture" :type "System.Globalization.CultureInfo" :readable t :writeable t :get-method "get_CurrentCulture" :set-method "set_CurrentCulture" :documentation (:summary "Gets or sets the culture for the current thread." :returns "An object that represents the culture for the current thread.")) (:name "CurrentPrincipal" :type "System.Security.Principal.IPrincipal" :readable t :writeable t :static t :get-method "get_CurrentPrincipal" :set-method "set_CurrentPrincipal" :documentation (:summary "Gets or sets the thread's current principal (for role-based security)." :returns "An System.Security.Principal.IPrincipal value representing the security context.")) (:name "CurrentThread" :type "System.Threading.Thread" :readable t :static t :get-method "get_CurrentThread" :documentation (:summary "Gets the currently running thread." :returns "A System.Threading.Thread that is the representation of the currently running thread.")) (:name "CurrentUICulture" :type "System.Globalization.CultureInfo" :readable t :writeable t :get-method "get_CurrentUICulture" :set-method "set_CurrentUICulture" :documentation (:summary "Gets or sets the current culture used by the Resource Manager to look up culture-specific resources at run time." :returns "An object that represents the current culture.")) (:name "ExecutionContext" :type "System.Threading.ExecutionContext" :readable t :get-method "get_ExecutionContext" :documentation (:summary "Gets an System.Threading.ExecutionContext object that contains information about the various contexts of the current thread." :returns "An System.Threading.ExecutionContext object that consolidates context information for the current thread.")) (:name "IsAlive" :type "System.Boolean" :readable t :get-method "get_IsAlive" :documentation (:summary "Gets a value indicating the execution status of the current thread." :returns "if this thread has been started and has not terminated normally or aborted; otherwise, .")) (:name "IsBackground" :type "System.Boolean" :readable t :writeable t :get-method "get_IsBackground" :set-method "set_IsBackground" :documentation (:summary "Gets or sets a value indicating whether or not a thread is a background thread." :returns "if this thread is or is to become a background thread; otherwise, .")) (:name "IsThreadPoolThread" :type "System.Boolean" :readable t :get-method "get_IsThreadPoolThread" :documentation (:summary "Gets a value indicating whether or not a thread belongs to the managed thread pool." :returns "if this thread belongs to the managed thread pool; otherwise, .")) (:name "ManagedThreadId" :type "System.Int32" :readable t :get-method "get_ManagedThreadId" :documentation (:summary "Gets a unique identifier for the current managed thread." :returns "An integer that represents a unique identifier for this managed thread.")) (:name "Name" :type "System.String" :readable t :writeable t :get-method "get_Name" :set-method "set_Name" :documentation (:summary "Gets or sets the name of the thread." :returns "A string containing the name of the thread, or if no name was set.")) (:name "Priority" :type "System.Threading.ThreadPriority" :readable t :writeable t :get-method "get_Priority" :set-method "set_Priority" :documentation (:summary "Gets or sets a value indicating the scheduling priority of a thread." :returns "One of the System.Threading.ThreadPriority values. The default value is System.Threading.ThreadPriority.Normal.")) (:name "ThreadState" :type "System.Threading.ThreadState" :readable t :get-method "get_ThreadState" :documentation (:summary "Gets a value containing the states of the current thread." :returns "One of the System.Threading.ThreadState values indicating the state of the current thread. The initial value is System.Threading.ThreadState.Unstarted."))) :constructors ((:public t :parameters ((:name "start" :type "System.Threading.ThreadStart")) :documentation (:summary "Initializes a new instance of the System.Threading.Thread class." :parameters ((:name "start" :description "A System.Threading.ThreadStart delegate that represents the methods to be invoked when this thread begins executing.")))) (:public t :parameters ((:name "start" :type "System.Threading.ParameterizedThreadStart")) :documentation (:summary "Initializes a new instance of the System.Threading.Thread class, specifying a delegate that allows an object to be passed to the thread when the thread is started." :parameters ((:name "start" :description "A delegate that represents the methods to be invoked when this thread begins executing.")))) (:public t :parameters ((:name "start" :type "System.Threading.ThreadStart") (:name "maxStackSize" :type "System.Int32")) :documentation (:summary "Initializes a new instance of the System.Threading.Thread class, specifying the maximum stack size for the thread." :parameters ((:name "start" :description "A System.Threading.ThreadStart delegate that represents the methods to be invoked when this thread begins executing.") (:name "maxStackSize" :description "The maximum stack size, in bytes, to be used by the thread, or 0 to use the default maximum stack size specified in the header for the executable. Important For partially trusted code, maxStackSize is ignored if it is greater than the default stack size. No exception is thrown.")))) (:public t :parameters ((:name "start" :type "System.Threading