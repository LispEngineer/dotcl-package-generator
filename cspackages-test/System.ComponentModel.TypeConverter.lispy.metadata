e" :type "System.Boolean" :readable t :writeable t :get-method "get_Visible" :set-method "set_Visible" :documentation (:summary "Gets or sets a value indicating whether this menu item is visible." :returns "if the item is visible; otherwise, ."))) :events ((:name "CommandChanged" :type "System.EventHandler" :add-method "add_CommandChanged" :remove-method "remove_CommandChanged" :documentation (:summary "Occurs when the menu command changes."))) :constructors ((:public t :parameters ((:name "handler" :type "System.EventHandler") (:name "command" :type "System.ComponentModel.Design.CommandID")) :documentation (:summary "Initializes a new instance of the System.ComponentModel.Design.MenuCommand class." :parameters ((:name "handler" :description "The event to raise when the user selects the menu item or toolbar button.") (:name "command" :description "The unique command ID that links this menu command to the environment's menu."))))) :methods ((:name "Invoke" :return-type "System.Void" :documentation (:summary "Invokes the command.")) (:name "Invoke" :return-type "System.Void" :parameters ((:name "arg" :type "System.Object")) :documentation (:summary "Invokes the command with the given parameter." :parameters ((:name "arg" :description "An optional argument for use by the command.")))) (:name "OnCommandChanged" :return-type "System.Void" :parameters ((:name "e" :type "System.EventArgs")) :documentation (:summary "Raises the System.ComponentModel.Design.MenuCommand.CommandChanged event." :parameters ((:name "e" :description "An System.EventArgs that contains the event data.")))) (:name "ToString" :return-type "System.String" :documentation (:summary "Returns a string representation of this menu command." :returns "A string containing the value of the System.ComponentModel.Design.MenuCommand.CommandID property appended with the names of any flags that are set, separated by pipe bars (|). These flag properties include System.ComponentModel.Design.MenuCommand.Checked, Syste