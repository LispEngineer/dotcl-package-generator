ntainers; otherwise, .")))) (:name "AddService" :return-type "System.Void" :parameters ((:name "serviceType" :type "System.Type") (:name "callback" :type "System.ComponentModel.Design.ServiceCreatorCallback") (:name "promote" :type "System.Boolean")) :documentation (:summary "Adds the specified service to the service container, and optionally promotes the service to parent service containers." :parameters ((:name "serviceType" :description "The type of service to add.") (:name "callback" :description "A callback object that is used to create the service. This allows a service to be declared as available, but delays the creation of the object until the service is requested.") (:name "promote" :description "to promote this request to any parent service containers; otherwise, .")))) (:name "RemoveService" :return-type "System.Void" :parameters ((:name "serviceType" :type "System.Type")) :documentation (:summary "Removes the specified service type from the service container." :parameters ((:name "serviceType" :description "The type of service to remove.")))) (:name "RemoveService" :return-type "System.Void" :parameters ((:name "serviceType" :type "System.Type") (:name "promote" :type "System.Boolean")) :documentation (:summary "Removes the specified service type from the service container, and optionally promotes the service to parent service containers." :parameters ((:name "serviceType" :description "The type of service to remove.") (:name "promote" :description "to promote this request to any parent service containers; otherwise, ."))))))
