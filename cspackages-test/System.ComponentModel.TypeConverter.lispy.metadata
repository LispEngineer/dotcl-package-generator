  (:name "IComponentChangeService" :fully-qualified-name "System.ComponentModel.Design.IComponentChangeService" :namespace "System.ComponentModel.Design" :kind :interface :documentation (:summary "Provides an interface to add and remove the event handlers for events that add, change, remove or rename components, and provides methods to raise a System.ComponentModel.Design.IComponentChangeService.ComponentChanged or System.ComponentModel.Design.IComponentChangeService.ComponentChanging event.") :flags (:abstract) :events ((:name "ComponentAdded" :type "System.ComponentModel.Design.ComponentEventHandler" :add-method "add_ComponentAdded" :remove-method "remove_ComponentAdded" :documentation (:summary "Occurs when a component has been added.")) (:name "ComponentAdding" :type "System.ComponentModel.Design.ComponentEventHandler" :add-method "add_ComponentAdding" :remove-method "remove_ComponentAdding" :documentation (:summary "Occurs when a component is in the process of being added.")) (:name "ComponentChanged" :type "System.ComponentModel.Design.ComponentChangedEventHandler" :add-method "add_ComponentChanged" :remove-method "remove_ComponentChanged" :documentation (:summary "Occurs when a component has been changed.")) (:name "ComponentChanging" :type "System.ComponentModel.Design.ComponentChangingEventHandler" :add-method "add_ComponentChanging" :remove-method "remove_ComponentChanging" :documentation (:summary "Occurs when a component is in the process of being changed.")) (:name "ComponentRemoved" :type "System.ComponentModel.Design.ComponentEventHandler" :add-method "add_ComponentRemoved" :remove-method "remove_ComponentRemoved" :documentation (:summary "Occurs when a component has been removed.")) (:name "ComponentRemoving" :type "System.ComponentModel.Design.ComponentEventHandler" :add-method "add_ComponentRemoving" :remove-method "remove_ComponentRemoving" :documentation (:summary "Occurs when a component is in the process of being removed.")) (:name "ComponentRe