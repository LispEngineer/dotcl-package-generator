  (:name "IHelpService" :fully-qualified-name "System.ComponentModel.Design.IHelpService" :namespace "System.ComponentModel.Design" :kind :interface :documentation (:summary "Provides methods for showing Help topics and adding and removing Help keywords at design time.") :flags (:abstract) :methods ((:name "AddContextAttribute" :return-type "System.Void" :parameters ((:name "name" :type "System.String") (:name "value" :type "System.String") (:name "keywordType" :type "System.ComponentModel.Design.HelpKeywordType")) :documentation (:summary "Adds a context attribute to the document." :parameters ((:name "name" :description "The name of the attribute to add.") (:name "value" :description "The value of the attribute.") (:name "keywordType" :description "The type of the keyword, from the enumeration System.ComponentModel.Design.HelpKeywordType.")))) (:name "ClearContextAttributes" :return-type "System.Void" :documentation (:summary "Removes all existing context attributes from the document.")) (:name "CreateLocalContext" :return-type "System.ComponentModel.Design.IHelpService" :parameters ((:name "contextType" :type "System.ComponentModel.Design.HelpContextType")) :documentation (:summary "Creates a local System.ComponentModel.Design.IHelpService to manage subcontexts." :returns "The newly created System.ComponentModel.Design.IHelpService." :parameters ((:name "contextType" :description "The priority type of the subcontext to add.")))) (:name "RemoveContextAttribute" :return-type "System.Void" :parameters ((:name "name" :type "System.String") (:name "value" :type "System.String")) :documentation (:summary "Removes a previously added context attribute." :parameters ((:name "name" :description "The name of the attribute to remove.") (:name "value" :description "The value of the attribute to remove.")))) (:name "RemoveLocalContext" :return-type "System.Void" :parameters ((:name "localContext" :type "System.ComponentModel.Design.IHelpService")) :documentation (:summary "Removes a context created with System.ComponentModel.Design.IHelpService.CreateLocalContext(System.ComponentModel.Design.HelpContextType)." :parameters ((:name "localContext" :description "The local context System.ComponentModel.Design.IHelpService to remove.")))) (:name "ShowHelpFromKeyword" :return-type "System.Void" :parameters ((:name "helpKeyword" :type "System.String")) :documentation (:summary "Shows the Help topic that corresponds to the specified keyword." :parameters ((:name "helpKeyword" :description "The keyword of the Help topic to display.")))) (:name "ShowHelpFromUrl" :return-type "System.Void" :parameters ((:name "helpUrl" :type "System.String")) :documentation (:summary "Shows the Help topic that corresponds to the specified URL." :parameters ((:name "helpUrl" :description "The URL of the Help topic to display."))))))
  (:name "IInheritanceService" :fully-qualified-name "System.ComponentModel.Design.IInheritanceService" :namespace "System.ComponentModel.Design" :kind :interface :documentation (:summary "Provides methods for identifying the components of a component.") :flags (:abstract) :methods ((:name "AddInheritedComponents" :return-type "System.Void" :parameters ((:name "component" :type "System.ComponentModel.IComponent") (:name "container" :type "System.ComponentModel.IContainer")) :documentation (:summary "Searches the specified component for fields that implement the System.ComponentModel.IComponent interface and adds each to the specified container, storing the inheritance level of each which can be retrieved using the System.ComponentModel.Design.IInheritanceService.GetInheritanceAttribute(System.ComponentModel.IComponent) method." :parameters ((:name "component" :description "The System.ComponentModel.IComponent to search. Searching begins with this component.") (:name "container" :description "The System.ComponentModel.IContainer to add components to.")))) (:name "GetInheritanceAttribute" :return-type "System.ComponentModel.InheritanceAttribute" :parameters ((:name "component" :type "System.ComponentModel.IComponent")) :documentation (:summary "Gets the inheritance attribute for the specified component." :returns "An instance of System.ComponentModel.InheritanceAttribute that describes the level of inheritance of the specified component." :parameters ((:name "component" :description "The System.ComponentModel.IComponent for which to retrieve the inheritance attribute."))))))
  (:name "IMenuCommandService" :fully-qualified-name "System.ComponentModel.Design.IMenuCommandService" :namespace "System.ComponentModel.Design" :kind :interface :documentation (:summary "Provides methods to manage the global designer verbs and menu commands available in design mode, and to show some types of shortcut menus.") :flags (:abstract) :properties ((:name "Verbs" :type "System.ComponentModel.Design.DesignerVerbCollection" :readable t :get-method "get_Verbs" :documentation (:summary "Gets a collection of the designer verbs that are currently available." :returns "A System.ComponentModel.Design.DesignerVerbCollection that contains the designer verbs that are currently available."))) :methods ((:name "AddCommand" :return-type "System.Void" :parameters ((:name "command" :type "System.ComponentModel.Design.MenuCommand")) :documentation (:summary "Adds the specified standard menu command to the menu." :parameters ((:name "command" :description "The System.ComponentModel.Design.MenuCommand to add.")))) (:name "AddVerb" :return-type "System.Void" :parameters ((:name "verb" :type "System.ComponentModel.Design.DesignerVerb")) :documentation (:summary "Adds the specified designer verb to the set of global designer verbs." :parameters ((:name "verb" :description "The System.ComponentModel.Design.DesignerVerb to add.")))) (:name "FindCommand" :return-type "System.ComponentModel.Design.MenuCommand" :parameters ((:name "commandID" :type "System.ComponentModel.Design.CommandID")) :documentation (:summary "Searches for the specified command ID and returns the menu command associated with it." :returns "The System.ComponentModel.Design.MenuCommand associated with the command ID, or if no command is found." :parameters ((:name "commandID" :description "The System.ComponentModel.Design.CommandID to search for.")))) (:name "GlobalInvoke" :return-type "System.Boolean" :parameters ((:name "commandID" :type "System.ComponentModel.Design.CommandID")) :documentation (:summary "Invokes a menu or designer verb command matching the specified command ID." :returns "if the command was found and invoked successfully; otherwise, ." :parameters ((:name "commandID" :description "The System.ComponentModel.Design.CommandID of the command to search for and execute.")))) (:name "RemoveCommand" :return-type "System.Void" :parameters ((:name "command" :type "System.ComponentModel.Design.MenuCommand")) :documentation (:summary "Removes the specified standard menu command from the menu." :parameters ((:name "command" :description "The System.ComponentModel.Design.MenuCommand to remove.")))) (:name "RemoveVerb" :return-type "System.Void" :parameters ((:name "verb" :type "System.ComponentModel.Design.DesignerVerb")) :documentation (:summary "Removes the specified designer verb from the collection of global designer verbs." :parameters ((:name "verb" :description "The System.ComponentModel.Design.DesignerVerb to remove.")))) (:name "ShowContextMenu" :return-type "System.Void" :parameters ((:name "menuID" :type "System.ComponentModel.Design.CommandID") (:name "x" :type "System.Int32") (:name "y" :type "System.Int32")) :documentation (:summary "Shows the specified shortcut menu at the specified location." :parameters ((:name "menuID" :description "The System.ComponentModel.Design.CommandID for the shortcut menu to show.") (:name "x" :description "The x-coordinate at which to display the menu, in screen coordinates.") (:name "y" :description "The y-coordinate at which to display the menu, in screen coordinates."))))))
  (:name "IReferenceService" :fully-qualified-name "System.ComponentModel.Design.IReferenceService" :namespace "System.ComponentModel.Design" :kind :interface :documentation (:summary "Provides an interface for obtaining references to objects within a project by name or type, obtaining the name of a specified object, and for locating the parent of a specified object within a designer project.") :flags (:abstract) :methods ((:name "GetComponent" :return-type "System.ComponentModel.IComponent" :parameters ((:name "reference" :type "System.Object")) :documentation (:summary "Gets the component that contains the specified component." :returns "The base System.ComponentModel.IComponent that contains the specified object, or if no parent component exists." :parameters ((:name "reference" :description "The object to retrieve the parent component for.")))) (:name "GetName" :return-type "System.String" :parameters ((:name "reference" :type "System.Object")) :documentation (:summary "Gets the name of the specified component." :returns "The name of the object referenced, or if the object reference is not valid." :parameters ((:name "reference" :description "The object to return the name of.")))) (:name "GetReference" :return-type "System.Object" :parameters ((:name "name" :type "System.String")) :documentation (:summary "Gets a reference to the component whose name matches the specified name." :returns "An object the specified name refers to, or if no reference is found." :parameters ((:name "name" :description "The name of the component to return a reference to.")))) (:name "GetReferences" :return-type "System.Object[]" :documentation (:summary "Gets all available references to project components." :returns "An array of all objects with references available to the System.ComponentModel.Design.IReferenceService.")) (:name "GetReferences" :return-type "System.Object[]" :parameters ((:name "baseType" :type "System.Type")) :documentation (:summary "Gets all available references to components of the specified type." :returns "An array of all available objects of the specified type." :parameters ((:name "baseType" :description "The type of object to return references to instances of."))))))
