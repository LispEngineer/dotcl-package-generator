  (:name "IEventBindingService" :fully-qualified-name "System.ComponentModel.Design.IEventBindingService" :namespace "System.ComponentModel.Design" :kind :interface :documentation (:summary "Provides a service for registering event handlers for component events.") :flags (:abstract) :methods ((:name "CreateUniqueMethodName" :return-type "System.String" :parameters ((:name "component" :type "System.ComponentModel.IComponent") (:name "e" :type "System.ComponentModel.EventDescriptor")) :documentation (:summary "Creates a unique name for an event-handler method for the specified component and event." :returns "The recommended name for the event-handler method for this event." :parameters ((:name "component" :description "The component instance the event is connected to.") (:name "e" :description "The event to create a name for.")))) (:name "GetCompatibleMethods" :return-type "System.Collections.ICollection" :parameters ((:name "e" :type "System.ComponentModel.EventDescriptor")) :documentation (:summary "Gets a collection of event-handler methods that have a method signature compatible with the specified event." :returns "A collection of strings." :parameters ((:name "e" :description "The event to get the compatible event-handler methods for.")))) (:name "GetEvent" :return-type "System.ComponentModel.EventDescriptor" :parameters ((:name "property" :type "System.ComponentModel.PropertyDescriptor")) :documentation (:summary "Gets an System.ComponentModel.EventDescriptor for the event that the specified property descriptor represents, if it represents an event." :returns "An System.ComponentModel.EventDescriptor for the event that the property represents, or if the property does not represent an event." :parameters ((:name "property" :description "The property that represents an event.")))) (:name "GetEventProperties" :return-type "System.ComponentModel.PropertyDescriptorCollection" :parameters ((:name "events" :type "System.ComponentModel.EventDescriptorCollection")) :documentation (:summary "Converts a set of event descriptors to a set of property descriptors." :returns "An array of System.ComponentModel.PropertyDescriptor objects that describe the event set." :parameters ((:name "events" :description "The events to convert to properties.")))) (:name "GetEventProperty" :return-type "System.ComponentModel.PropertyDescriptor" :parameters ((:name "e" :type "System.ComponentModel.EventDescriptor")) :documentation (:summary "Converts a single event descriptor to a property descriptor." :returns "A System.ComponentModel.PropertyDescriptor that describes the event." :parameters ((:name "e" :description "The event to convert.")))) (:name "ShowCode" :return-type "System.Boolean" :documentation (:summary "Displays the user code for the designer." :returns "if the code is displayed; otherwise, .")) (:name "ShowCode" :return-type "System.Boolean" :parameters ((:name "lineNumber" :type "System.Int32")) :documentation (:summary "Displays the user code for the designer at the specified line." :returns "if the code is displayed; otherwise, ." :parameters ((:name "lineNumber" :description "The line number to place the caret on.")))) (:name "ShowCode" :return-type "System.Boolean" :parameters ((:name "component" :type "System.ComponentModel.IComponent") (:name "e" :type "System.ComponentModel.EventDescriptor")) :documentation (:summary "Displays the user code for the specified event." :returns "if the code is displayed; otherwise, ." :parameters ((:name "component" :description "The component that the event is connected to.") (:name "e" :description "The event to display."))))))
