  (:name "MaskedTextProvider" :fully-qualified-name "System.ComponentModel.MaskedTextProvider" :namespace "System.ComponentModel" :kind :class :documentation (:summary "Represents a mask-parsing service that can be used by any number of controls that support masking, such as the System.Windows.Forms.MaskedTextBox control.") :superclass "System.Object" :interfaces ("System.ICloneable") :properties ((:name "AllowPromptAsInput" :type "System.Boolean" :readable t :get-method "get_AllowPromptAsInput" :documentation (:summary "Gets a value indicating whether the prompt character should be treated as a valid input character or not." :returns "if the user can enter System.ComponentModel.MaskedTextProvider.PromptChar into the control; otherwise, . The default is .")) (:name "AsciiOnly" :type "System.Boolean" :readable t :get-method "get_AsciiOnly" :documentation (:summary "Gets a value indicating whether the mask accepts characters outside of the ASCII character set." :returns "if only ASCII is accepted; if System.ComponentModel.MaskedTextProvider can accept any arbitrary Unicode character. The default is .")) (:name "AssignedEditPositionCount" :type "System.Int32" :readable t :get-method "get_AssignedEditPositionCount" :documentation (:summary "Gets the number of editable character positions that have already been successfully assigned an input value." :returns "An System.Int32 containing the number of editable character positions in the input mask that have already been assigned a character value in the formatted string.")) (:name "AvailableEditPositionCount" :type "System.Int32" :readable t :get-method "get_AvailableEditPositionCount" :documentation (:summary "Gets the number of editable character positions in the input mask that have not yet been assigned an input value." :returns "An System.Int32 containing the number of editable character positions that not yet been assigned a character value.")) (:name "Culture" :type "System.Globalization.CultureInfo" :readable t :ge