<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- DotCL.Runtime 0.1.18 is not yet published to nuget.org; this local
         feed is the ../dotcl checkout's own build output directory so
         `dotnet restore` can find it during development. Remove once
         0.1.18 is published upstream. -->
    <add key="dotcl-local" value="../dotcl/out" />
  </packageSources>
</configuration>
